DB_USER=postgres
DB_PASSWORD=your-db-pass
DB_HOST=localhost
DB_PORT=5433
DB_NAME=postgres
DATABASE_URL="postgresql://postgres:your-db-pass@localhost:5433/postgres"

SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Gemini API Configuration
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
MAX_FILE_SIZE_MB=20
ALLOWED_FILE_EXTENSIONS=[".jpg",".png",".jpeg",".webp",".heic",".heif",".pdf", ".pptx",".docx", ".doc", ".txt", ".html"]

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=your-redis-pass
REDIS_DECODE_RESPONSES=true
REDIS_MAX_CONNECTIONS=10

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=5
RATE_LIMIT_PER_HOUR=50

# Hugging Face Configuration
HF_TOKEN=your-hg-token

ML_API_URL=your-ml-api-url
# Kazakh ML API (optional; kk language returns 503 if unset)
ML_API_URL_KK=your-ml-api-url-kk

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret
STRIPE_PRICE_ID=price_your-subscription-price-id
FRONTEND_URL=http://localhost:3000
# Local dev: paste STRIPE_WEBHOOK_SECRET from: stripe listen --forward-to http://localhost:8000/api/v1/billing/webhook

# Email (production): set SMTP_HOST to send real verification mail; omit for dev (link logged only)
EMAIL_VERIFICATION_TOKEN_EXPIRE_HOURS=48
PASSWORD_RESET_TOKEN_EXPIRE_HOURS=24
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-account@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=your-account@gmail.com
SMTP_USE_TLS=true
SMTP_SSL=false

# Google Sign-In (optional). Set GOOGLE_OAUTH_ENABLED=true and fill client credentials.
# GOOGLE_ALLOWED_REDIRECT_URIS must include the exact redirect_uri the frontend sends (comma-separated).
# For @react-oauth/google auth-code + popup, use: postmessage
GOOGLE_OAUTH_ENABLED=true
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_ALLOWED_REDIRECT_URIS=postmessage
# Docker frontend: same ID is passed to `docker compose build` as NEXT_PUBLIC_GOOGLE_CLIENT_ID (or set NEXT_PUBLIC_GOOGLE_CLIENT_ID explicitly). Rebuild frontend after changing it.
